# Copy this file to kassensturz.env in the project root for local dev.
# For PyInstaller, use it as input for tools/create_bundled_config.py.
# Do not commit real secrets and do not ship this file with PyInstaller builds.
# Environment variables override this file.

KASSENSTURZ_MODE=debug
KASSENSTURZ_PRODUCTION_MODE=false
KASSENSTURZ_SECRET_KEY=replace-me
KASSENSTURZ_ADMIN_PASSWORD=admin

KASSENSTURZ_NEXTCLOUD_BASE_URL=
KASSENSTURZ_NEXTCLOUD_USERNAME=
KASSENSTURZ_NEXTCLOUD_APP_PASSWORD=
KASSENSTURZ_NEXTCLOUD_REMOTE_DIR=Apps/Kassensturz/Debug
KASSENSTURZ_NEXTCLOUD_REMOTE_FILE=kassensturz_data.xlsx
KASSENSTURZ_NEXTCLOUD_CA_CERT_PATH=
KASSENSTURZ_NEXTCLOUD_VERIFY=false
